{
  "compilerOptions": {
    "types": ["node", "jest"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@/*": [ "./src/*" ]
    }
  },
  "include": [ "src" ]
}